{
  "name": "citty-test-utils",
  "version": "1.0.2",
  "description": "Unified testing framework for CLI applications with auto-detecting local/cleanroom execution, vitest config integration, and simplified scenario DSL.",
  "type": "module",
  "main": "index.js",
  "workspaces": ["packages/*", "projects/*"],
  "bin": {
    "ctu": "./src/cli.mjs",
    "ctu-showcase": "./src/showcase.mjs",
    "citty-test-utils": "./src/cli.mjs"
  },
  "types": "src/types/types.d.ts",
  "keywords": [
    "testing",
    "cli",
    "citty",
    "docker",
    "testcontainers",
    "cleanroom",
    "assertions",
    "snapshot",
    "snapshot-testing",
    "noun-verb",
    "scenario-dsl",
    "template-generation",
    "file-generation",
    "citty-testing",
    "docker-cleanroom",
    "fluent-assertions",
    "test-scenarios",
    "cli-testing",
    "nodejs"
  ],
  "author": "GitVan Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seanchatmangpt/citty-test-utils.git"
  },
  "bugs": {
    "url": "https://github.com/seanchatmangpt/citty-test-utils/issues"
  },
  "homepage": "https://github.com/seanchatmangpt/citty-test-utils#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "c12": "^4.0.0-beta.5",
    "confbox": "^0.2.4",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "destr": "^2.0.5",
    "h3": "^2.0.1-rc.22",
    "hookable": "^6.1.1",
    "jiti": "^2.7.0",
    "magic-regexp": "^0.11.0",
    "mlly": "^1.8.2",
    "n3": "^1.26.0",
    "nanotar": "^0.3.0",
    "nunjucks": "^3.2.4",
    "nypm": "^0.6.6",
    "ofetch": "^1.5.1",
    "ohash": "^2.0.11",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "proper-lockfile": "^4.1.2",
    "rc9": "^3.0.1",
    "scule": "^1.3.0",
    "std-env": "^4.1.0",
    "testcontainers": "^10.0.0",
    "ufo": "^1.6.4",
    "uncrypto": "^0.1.3",
    "unenv": "^1.10.0",
    "unstorage": "^1.17.5",
    "unwasm": "^0.5.3",
    "uqr": "^0.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "automd": "^0.4.3",
    "bundle-runner": "^0.0.1",
    "changelogen": "^0.6.2",
    "citty": "^0.1.6",
    "crossws": "^0.4.5",
    "db0": "^0.3.4",
    "fontaine": "^0.8.0",
    "get-port-please": "^3.2.0",
    "httpxy": "^0.5.3",
    "image-meta": "^0.2.2",
    "ipx": "^3.1.1",
    "jimp-compact": "^0.16.1-2",
    "knitwork": "^1.3.0",
    "listhen": "^1.10.0",
    "magicast": "^0.5.3",
    "mkdist": "^2.4.1",
    "nitro": "^3.0.260603-beta",
    "perfect-debounce": "^2.1.0",
    "unbuild": "^3.6.1",
    "undocs": "^0.4.16",
    "ungh": "^0.0.0",
    "unhead": "^3.1.3",
    "unimport": "^6.3.0",
    "unpdf": "^1.6.2",
    "unplugin": "^3.0.0",
    "untun": "^0.1.3",
    "untyped": "^2.0.0",
    "vitest": "^1.0.0",
    "webpackbar": "^7.0.0"
  },
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:citty-integration": "vitest run test/integration/citty-integration.test.mjs",
    "test:bdd": "vitest run test/bdd",
    "test:readme": "vitest run test/readme",
    "test:cleanroom": "vitest run test/integration/cleanroom*.test.mjs",
    "test:docker": "vitest run test/integration/cleanroom*.test.mjs",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:enterprise": "vitest run test/enterprise",
    "test:compliance": "vitest run test/compliance",
    "test:performance": "vitest run test/performance",
    "test:enterprise-runner": "vitest run test/enterprise/enterprise-test-runner.test.mjs",
    "test:snapshot": "vitest run --update",
    "test:changed": "vitest run --changed",
    "test:failed": "vitest run --reporter=verbose --bail",
    "demo": "node demo.mjs",
    "demo:enterprise": "node demo-enterprise.js"
  },
  "files": [
    "index.js",
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
